<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Bouton pour aller à l'écran de recherche -->
    <Button
        android:id="@+id/btnRecherche"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔍 Rechercher"
        android:backgroundTint="#3478F6"
        android:layout_marginBottom="8dp"/>

    <!-- Bouton pour aller à l'écran d'ajout -->
    <Button
        android:id="@+id/btnAjouter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ Ajouter un chanteur"
        android:backgroundTint="#34A853"
        android:layout_marginBottom="16dp"/>

    <!-- Liste des chanteurs -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Message affiché si la liste est vide -->
    <TextView
        android:id="@+id/tvVide"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aucun chanteur enregistré."
        android:textAlignment="center"
        android:visibility="gone"
        android:layout_marginTop="40dp"
        android:alpha="0.6"/>

</LinearLayout>